# Import Required Libraries
import pandas as pd
import numpy as np

# ---------------------------------------------------------
# STEP 1 : Create Dataset
# ---------------------------------------------------------
# Name        -> Student/Person Name
# Age_Group   -> Categorical Variable
# Income      -> Numerical Variable

data = {
    "Name": ["Amit", "Neha", "Raj", "Priya", "Kiran",
             "Sara", "Tom", "Anu", "Ravi", "John"],

    "Age_Group": ["18-20", "18-20", "21-23", "21-23", "18-20",
                  "21-23", "18-20", "21-23", "18-20", "21-23"],

    "Income": [25000, 30000, 40000, 35000, 28000,
               45000, 32000, 38000, 29000, 42000]
}

# Convert dictionary into DataFrame
df = pd.DataFrame(data)

print("------------ DATASET ------------")
print(df)

# ---------------------------------------------------------
# STEP 2 : Group Data by Categorical Variable
# ---------------------------------------------------------
# groupby() groups rows having same Age_Group
# Here we group Income according to Age_Group
# To divide data into groups based on categories.

group = df.groupby("Age_Group")["Income"]

# ---------------------------------------------------------
# STEP 3 : Calculate Descriptive Statistics
# ---------------------------------------------------------

print("\n------------ SUMMARY STATISTICS ------------")

# Mean = Average value
# Formula:
# Mean = Sum of all observations / Number of observations

print("Mean")
print(group.mean())

# Median = Middle value after sorting data
# Used when data contains outliers

print("\nMedian")
print(group.median())

# Minimum = Smallest value in group

print("\nMinimum")
print(group.min())

# Maximum = Largest value in group

print("\nMaximum")
print(group.max())

# Standard Deviation = Measure of data spread
# Small SD -> data close to mean
# Large SD -> data widely spread

print("\nStandard Deviation")
print(group.std())

# ---------------------------------------------------------
# STEP 4 : Create List of Income for Each Age Group
# ---------------------------------------------------------
# apply(list) converts grouped values into list format

print("\n------------ INCOME LIST BY AGE GROUP ------------")

income_list = group.apply(list)

print(income_list)

# =========================================================
# THEORY / VIVA POINTS
# =========================================================
# 1. Central Tendency:
#    - Mean
#    - Median
#    - Mode
#
# 2. Variability Measures:
#    - Range
#    - Variance
#    - Standard Deviation
#
# 3. groupby():
#    Used to split data into groups based on categories.
#
# 4. DataFrame:
#    Two-dimensional table in pandas.
#
# 5. Why Standard Deviation is important?
#    It shows how much data varies from the average.
#
# 6. Difference between Mean and Median:
#    Mean  -> affected by extreme values
#    Median -> not affected by outliers
